generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String               @id @default(cuid())
  name                     String?
  email                    String               @unique
  emailVerified            DateTime?
  hashedPassword           String?
  image                    String?
  role                     String               @default("FREE")
  onboardingCompleted      Boolean              @default(false)
  aiTools                  String[]             @default([])
  primaryConcern           String?
  occupationalRole         String?
  goviInterface            String               @default("terminal") // terminal | sovereign — chosen Govi UI skin
  stripeCustomerId         String?              @unique
  stripeSubscriptionId     String?              @unique
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  conversations            Conversation[]
  passwordResetTokens      PasswordResetToken[]
  generatedArtifacts       GeneratedArtifact[]
  workflowSessions         WorkflowSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Conversation")
  /**
   * Phase 4.5 — JSON-as-string blob holding the conversation-scoped
   * `OrgContext` (organization name, industry, size, governance lead,
   * escalation path, known AI tools, risk appetite, jurisdictions).
   * Serialized via `JSON.stringify` in `src/lib/ai/orgContext.ts`.
   */
  metadata  String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  generatedArtifacts GeneratedArtifact[]
  workflowSessions   WorkflowSession[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  riskLevel      String?
  confidence     Float?
  artifactType   String?      // "intake" | "document" | "playbook" — set when message triggered artifact generation
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model RateLimit {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  createdAt DateTime @default(now())

  @@index([userId, endpoint, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model KnowledgeEntry {
  id         String                      @id @default(cuid())
  title      String
  content    String                      @db.Text
  category   String
  tags       String[]
  isActive   Boolean                     @default(true)
  source     String?
  sourceType String                      @default("manual") // "manual" | "sector" | "regulation" | "nist" | "static"
  embedding  Unsupported("vector(1536)")?
  embeddedAt DateTime?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@index([isActive, category])
  @@index([sourceType])
}

model TokenUsage {
  id              String   @id @default(cuid())
  userId          String
  endpoint        String   // "advisor" | "advisor/stream" | "orchestrator"
  promptTokens    Int
  completionTokens Int
  totalTokens     Int
  model           String   @default("gpt-4o")
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, endpoint, createdAt])
}

/**
 * Multi-turn document workflow state — Phase 3.5.
 *
 * Used for TPRM, 90-Day Blueprint progress tracking, and any other long-running
 * questionnaire that needs to survive across browser refreshes and pause/resume.
 *
 * `state` is an opaque JSON blob shaped by `WorkflowOrchestrator`; treat it as
 * a private contract between the orchestrator and Prisma.
 */
model WorkflowSession {
  id             String        @id @default(cuid())
  userId         String
  conversationId String?
  workflowType   String        // 'tprm' | '90day-blueprint' | 'risk-assessment'
  status         String        @default("in-progress") // 'in-progress' | 'paused' | 'completed' | 'abandoned'
  currentStep    Int           @default(0)
  totalSteps     Int
  state          String        @db.Text // JSON: answers / scores / red-flags
  artifactId     String?       // GeneratedArtifact link, set when finalized
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([conversationId])
}

model GeneratedArtifact {
  id              String        @id @default(cuid())
  userId          String
  conversationId  String?
  type            String        // "intake" | "document" | "playbook"
  subType         String?       // "dpia", "threat-model", "NIST AI RMF", etc.
  title           String
  riskTier        String?
  useCaseName     String?
  content         String        @db.Text
  markdownExport  String        @db.Text
  version         Int           @default(1)
  parentId        String?       // points to the original artifact in the version chain
  changeNote      String?       // optional note describing what changed in this version
  reviewStatus    String        @default("draft") // Tier 2: draft | in-review | approved
  reviewedById    String?       // user who approved
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([conversationId])
  @@index([parentId])
}

model Organization {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  plan      String      @default("TEAM") // "TEAM" | "ENTERPRISE"
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  members   OrgMember[]
  invitations OrgInvitation[]

  @@index([slug])
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("MEMBER") // "OWNER" | "ADMIN" | "MEMBER"
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  name      String   // e.g. "My Slack", "GRC Tool"
  url       String   // HTTPS endpoint
  secret    String?  // HMAC signing secret for verification
  events    String[] // e.g. ["artifact.created", "artifact.versioned"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

model IntentFeedback {
  id             String   @id @default(cuid())
  userId         String
  query          String   @db.Text
  detectedIntent String   // what the classifier detected
  correctedIntent String? // what the user corrected to (null = confirmed)
  documentType   String?
  framework      String?
  createdAt      DateTime @default(now())

  @@index([detectedIntent, correctedIntent])
  @@index([userId, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String   // e.g. "query", "artifact_generated", "export", "login", "error"
  category  String   // e.g. "advisor", "intake", "document", "playbook", "auth", "system"
  metadata  String?  @db.Text // JSON blob with event-specific data
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([category, createdAt])
}

// ─── AAA governance foundation (Tiers 1–3) ──────────────────────────────────

/// Tier 1a — AI System Inventory / Register. One row per AI use case an org runs.
model AiSystem {
  id             String    @id @default(cuid())
  userId         String    // creator / owner in personal scope
  organizationId String?   // when set, shared across the org (Tier 2)
  name           String
  description    String?   @db.Text
  purpose        String?   @db.Text
  businessOwner  String?
  vendor         String?
  model          String?
  lifecycleStage String    @default("idea")     // idea | piloting | production | retired
  riskCategory   String    @default("limited")  // prohibited | high | limited | minimal (EU AI Act)
  status         String    @default("active")   // active | archived
  dataTypes      String[]  @default([])
  deployedAt     DateTime?
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, status])
  @@index([organizationId])
  @@index([riskCategory])
  @@index([nextReviewAt])
}

/// Tier 1b — per-control implementation status for a compliance framework.
model ControlAssessment {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  framework      String   // "NIST-AI-RMF" | "ISO-42001" | "EU-AI-Act"
  controlId      String   // e.g. "GOVERN-1.1"
  status         String   @default("not-started") // not-started | in-progress | implemented | not-applicable
  evidence       String?  @db.Text
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, framework, controlId])
  @@index([organizationId, framework])
}

/// Tier 1c — remediation / action tracker item.
model RemediationTask {
  id             String    @id @default(cuid())
  userId         String    // creator
  organizationId String?
  title          String
  description    String?   @db.Text
  status         String    @default("todo")   // todo | in-progress | done
  priority       String    @default("medium") // low | medium | high | critical
  dueDate        DateTime?
  assigneeId     String?
  aiSystemId     String?
  framework      String?
  controlId      String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([assigneeId])
  @@index([dueDate])
}

/// Tier 1d — immutable governance audit trail.
model AuditLogEntry {
  id             String   @id @default(cuid())
  organizationId String?
  actorId        String   // user who performed the action
  action         String   // "ai_system.created" | "control.updated" | "task.completed" | "artifact.approved"
  entityType     String   // "ai_system" | "control" | "task" | "artifact"
  entityId       String?
  summary        String
  metadata       String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

/// Tier 2 — pending team invitation.
model OrgInvitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String       @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER
  tokenHash      String       @unique
  invitedById    String
  status         String       @default("pending") // pending | accepted | revoked | expired
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email])
}

/// Tier 3 — point-in-time maturity score for trend charts.
model MaturitySnapshot {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  score          Int      // 0–100 overall
  dimensions     String   @db.Text // JSON: { inventory, controls, reviewCadence, remediation }
  source         String   @default("computed") // computed | assessment
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
}

/// Tier 3 — a document the user uploaded, embedded for retrieval by the advisor (RAG).
model UserDocument {
  id         String              @id @default(cuid())
  userId     String
  fileName   String
  framework  String?
  charCount  Int                 @default(0)
  chunkCount Int                 @default(0)
  createdAt  DateTime            @default(now())
  chunks     UserDocumentChunk[]

  @@index([userId, createdAt])
}

/// A single embedded chunk of a UserDocument. Vector column managed via raw SQL.
model UserDocumentChunk {
  id         String                       @id @default(cuid())
  documentId String
  userId     String
  chunkIndex Int
  content    String                       @db.Text
  embedding  Unsupported("vector(1536)")?
  embeddedAt DateTime?
  createdAt  DateTime                     @default(now())
  document   UserDocument                 @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
}

/// Tier 3 — regulatory horizon-scanning feed item.
model RegulatoryUpdate {
  id           String   @id @default(cuid())
  title        String
  summary      String   @db.Text
  jurisdiction String   // "EU" | "US-CA" | "US-Federal" | "UK" | "Global"
  framework    String?  // "EU-AI-Act" | "NIST-AI-RMF" | ...
  severity     String   @default("info") // info | notable | critical
  url          String?
  publishedAt  DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([isActive, publishedAt])
  @@index([jurisdiction])
}