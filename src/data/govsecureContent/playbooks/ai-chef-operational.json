            "",
            "What this workbook is",
            "A working set of templates for SMB AI governance: RACI, risk tiering, system registry, evidence tracking, and a lightweight executive dashboard."
          ],
          [
            "",
            "How to start",
            "1) Review the RACI. 2) Use the Intake and Tiering sheet for every new use case. 3) Register every AI system. 4) Review the Dashboard monthly or quarterly."
          ],
          [
            "",
            "Sample company",
            "HarborCraft Home Goods - a 280-person ecommerce and operations business."
          ],
          [
            "",
            "Important rule",
            "If a tool has no named owner, no risk tier, or no review date, it is not production-ready."
          ]
        ]
      ]
